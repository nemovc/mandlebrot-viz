{
	"name": "mandelbrot-viz",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"prebuild": "bash scripts/build-wasm.sh",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "npm run build && wrangler dev",
		"prepare": "svelte-kit sync; husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"gen": "wrangler types",
		"lint": "eslint . && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint:fix": "eslint . --fix && prettier . --write && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run",
		"format": "prettier . --write",
		"deploy": "npm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json,css}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/leaflet": "^1.9.21",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.3",
		"wrangler": "^4.63.0"
	},
	"dependencies": {
		"fflate": "^0.8.2",
		"leaflet": "^1.9.4",
		"lucide-svelte": "^1.0.1",
		"webm-muxer": "^5.1.4"
	}
}
